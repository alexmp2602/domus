---
const servicios = [
  {
    titulo: "Manos y pies",
    descripcion: "Manicuras, pedicuras y tratamientos de uñas.",
  },
  {
    titulo: "Peluquería y barbería",
    descripcion: "Cortes, peinados, tintes y tratamientos capilares.",
  },
  {
    titulo: "Cuidado facial",
    descripcion:
      "Tratamientos faciales, maquillaje, tratamientos de cejas y pestañas.",
  },
  {
    titulo: "Tratamientos corporales",
    descripcion: "Masajes relajantes y exfoliaciones.",
  },
  {
    titulo: "Depilación",
    descripcion: "Depilación unisex con cera.",
  },
];
---

<div class="container px-4 md:px-6">
  <div class="flex flex-col items-center justify-center space-y-4 text-center">
    <div class="space-y-4">
      <div
        class="inline-block rounded-lg px-3 py-1 text-sm text-white shadow-lg"
        style="background-color: var(--color-secundario);"
      >
        Servicios
      </div>
      <h2 class="text-3xl font-bold tracking-tighter sm:text-5xl">
        Tratamientos de belleza
      </h2>
      <p
        class="max-w-[900px] text-gray-500 md:text-xl lg:text-xl xl:text-xl dark:text-gray-400"
      >
        Descubre nuestros tratamientos faciales, corporales, de manos y pies,
        peluquería y maquillaje.
      </p>
    </div>
  </div>
  <div
    class="mx-auto px-4 grid max-w-5xl items-center gap-6 pt-6 pb-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-12"
  >
    {servicios.map((servicio, index) => (
      <div
        id={`servicio-${index}`}
        class="grid gap-2 p-6 rounded-lg shadow-md border border-gray-300 dark:border-gray-600 hover:shadow-xl transition-shadow duration-300 ease-in-out min-h-[120px] bg-gradient-to-br from-pink-100 to-white dark:from-gray-700 dark:to-gray-800 text-gray-800 dark:text-gray-200"
      >
        <h3 class="text-lg font-bold">{servicio.titulo}</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          {servicio.descripcion}
        </p>
      </div>
    ))}
  </div>
</div>
