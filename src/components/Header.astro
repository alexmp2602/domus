---
import FlowerIcon from "../components/icons/Flower.astro";
---

<header
  class="sticky top-0 z-50 bg-white dark:bg-gray-800 px-4 lg:px-6 h-14 flex items-center shadow-md"
>
  <a class="flex items-center justify-center" href="#" aria-label="Inicio">
    <FlowerIcon class="h-6 w-6" />
    <span class="sr-only">Domus</span>
  </a>
  <nav class="ml-auto flex gap-4 sm:gap-6">
    <a
      class="text-sm font-medium hover:underline underline-offset-4 transition-colors duration-300 ease-in-out"
      href="#Servicios"
      aria-label="Nuestros Servicios"
    >
      Servicios
    </a>
    <a
      class="text-sm font-medium hover:underline underline-offset-4 transition-colors duration-300 ease-in-out"
      href="#Ubicación"
      aria-label="Ubicación de Domus"
    >
      Ubicación
    </a>
    {
      /* <a class="text-sm font-medium hover:underline underline-offset-4 transition-colors duration-300 ease-in-out" href="#" aria-label="Contacta con Domus">
      Contacto */
    }
  </nav>
  <script type="module" src="/smooth-scroll.js"></script>
</header>
