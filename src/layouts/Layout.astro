---
import "@fontsource/yeseva-one";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
    />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/domus-estetica-logo.webp" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.esteticadomus.com/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/jpg" href="/domus-icono-m.jpg" />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Yeseva+One&display=swap"
      as="style"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Yeseva+One&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- Google Tag Manager -->
    <script>
      (function (w: any, d: Document, s: string, l: string, i: string) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        (j as HTMLScriptElement).async = true;
        (j as HTMLScriptElement).src =
          "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        if (f.parentNode) {
          f.parentNode.insertBefore(j, f);
        }
      })(window, document, "script", "dataLayer", "GTM-P8XXQZ8C");
    </script>
    <!-- End Google Tag Manager -->

    <!-- Google Ads -->
    <script
      defer
      src="https://www.googletagmanager.com/gtag/js?id=AW-10887723938"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "AW-10887723938");
    </script>

    <!-- Datos estructurados para SEO -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Estética Domus",
        "url": "https://www.esteticadomus.com/",
        "logo": "https://www.esteticadomus.com/domus-logo.webp",
        "telephone": "+54 9 261 660 9363",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Dirección Ejemplo 123",
          "addressLocality": "Ciudad Ejemplo",
          "addressRegion": "Provincia Ejemplo",
          "postalCode": "1234",
          "addressCountry": "AR"
        }
      }
    </script>
  </head>
  <body class="relative text-black dark:text-white">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-P8XXQZ8C"
        height="0"
        width="0"
        style="display: none; visibility: hidden"
        loading="lazy"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --color-primario: rgb(208, 66, 125);
    --color-secundario: rgb(61, 61, 61);
    --color-fondo-rosa: rgb(252, 204, 220);
    --color-fondo-crema: rgb(255, 248, 220);
  }

  html {
    font-family: "Carme", "Roboto", system-ui, sans-serif;
    scroll-behavior: smooth;
  }

  body {
    font-family: "Carme", "Roboto", system-ui;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overscroll-behavior: none;
    background-color: var(--color-fondo-crema);
  }

  .btn-primario {
    background-color: var(--color-primario);
    color: white;
    text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.6); /* Mejora el contraste */
    border: 2px solid white; /* Agrega un borde para claridad */
    transition:
      background-color 0.3s ease,
      transform 0.2s ease;
  }

  .btn-primario:hover {
    background-color: rgba(208, 66, 125, 0.8);
    transform: scale(1.05);
  }

  h1,
  h2,
  h3 {
    color: var(--color-primario);
  }

  a {
    color: var(--color-primario);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }

  @media (prefers-color-scheme: dark) {
    body {
      color: rgb(245, 245, 245);
    }
  }
</style>
