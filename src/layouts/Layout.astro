---
import "@fontsource/yeseva-one";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="domus-logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Google tag (gtag.js) para Google Ads -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=AW-10887723938"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "AW-10887723938");
    </script>
  </head>
  <body class="relative text-black dark:text-white">
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --color-primario: rgb(208, 66, 125);
    --color-secundario: rgb(61, 61, 61);
    --color-fondo-rosa: rgb(252, 204, 220);
    --color-fondo-crema: rgb(255, 248, 220);
  }

  html {
    font-family: "Carme", "Roboto", system-ui, sans-serif;
    scroll-behavior: smooth;
  }

  body {
    font-family: "Carme", "Roboto", system-ui;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overscroll-behavior: none;
    background-color: var(--color-fondo-crema);
  }

  /* Color primario en componentes */
  .btn-primario {
    background-color: var(--color-primario);
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 5px;
    cursor: pointer;
    transition: background-color 0.3s;
  }

  .btn-primario:hover {
    background-color: rgba(208, 66, 125, 0.8);
  }

  /* Encabezados con color primario */
  h1,
  h2,
  h3 {
    color: var(--color-primario);
  }

  /* Enlaces con color primario */
  a {
    color: var(--color-primario);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }

  @media (prefers-color-scheme: dark) {
    body {
      color: rgb(245, 245, 245);
    }
  }
</style>
